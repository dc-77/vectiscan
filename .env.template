# VectiScan — Production Environment Variables
# Copy to .env and fill in actual values before deployment.
#
# Required GitLab CI/CD Variables (Settings → CI/CD → Variables):
#   DB_USER, DB_PASSWORD, DB_NAME,
#   MINIO_ACCESS_KEY, MINIO_SECRET_KEY,
#   ANTHROPIC_API_KEY, VECTISCAN_ACCESS_PASSWORD

# --- PostgreSQL ---
DB_USER=vectiscan
DB_PASSWORD=CHANGE_ME
DB_NAME=vectiscan

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME

# --- Claude API (Report-Worker) ---
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# --- Access Password (Frontend Login) ---
VECTISCAN_ACCESS_PASSWORD=CHANGE_ME

# --- Passive Intelligence APIs (Scan-Worker, Phase 0a) ---
SHODAN_API_KEY=
ABUSEIPDB_API_KEY=
SECURITYTRAILS_API_KEY=

# --- Threat Intelligence (Scan-Worker, Phase 3) ---
NVD_API_KEY=

# --- WPScan (WordPress vulnerability scanner) ---
WPSCAN_API_TOKEN=

# --- Stripe Payment Flow (PA-1 / VEC-33) ---
# Von der CEO als Deploy-Secrets zu liefern. Ohne STRIPE_SECRET_KEY werden
# KEINE Abos aktiviert (POST /api/subscriptions -> 503 payment_not_configured).
# Live: sk_live_... / whsec_... | Staging-Test: sk_test_... / whsec_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price-ID je Paket; STRIPE_PRICE_DEFAULT als Fallback fuer alle Pakete.
STRIPE_PRICE_DEFAULT=
STRIPE_PRICE_WEBCHECK=
STRIPE_PRICE_PERIMETER=
STRIPE_PRICE_COMPLIANCE=
STRIPE_PRICE_SUPPLYCHAIN=
STRIPE_PRICE_INSURANCE=
# Redirect-URLs nach Checkout (optional, sonst aus APP_BASE_URL abgeleitet).
APP_BASE_URL=https://scan.vectigal.tech
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
# --- E-Mail (Resend) + Lead-Routing (VEC-36) ---
# Ohne RESEND_API_KEY ist der E-Mail-Versand deaktiviert; Leads werden trotzdem
# in der DB persistiert und sind ueber GET /api/leads (Admin) abrufbar.
RESEND_API_KEY=
RESEND_FROM_EMAIL=VectiScan <noreply@vectigal.tech>
# Routing-Ziel fuer eingehende Demo-/Lead-Anfragen (Vertriebs-Posteingang).
# Marken-Domain .gmbh (kundenseitig veroeffentlicht + betreut), NICHT .tech:
SALES_LEAD_EMAIL=kontakt@vectigal.gmbh

# --- Image Tag (set by CI/CD, default: latest) ---
TAG=latest
