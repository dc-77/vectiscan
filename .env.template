# VectiScan — Production Environment Variables
# Copy to .env and fill in actual values before deployment.
#
# Required GitLab CI/CD Variables (Settings → CI/CD → Variables):
#   DB_USER, DB_PASSWORD, DB_NAME,
#   MINIO_ACCESS_KEY, MINIO_SECRET_KEY,
#   ANTHROPIC_API_KEY, VECTISCAN_ACCESS_PASSWORD

# --- PostgreSQL ---
DB_USER=vectiscan
DB_PASSWORD=CHANGE_ME
DB_NAME=vectiscan

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME

# --- Claude API (Report-Worker) ---
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# --- Access Password (Frontend Login) ---
VECTISCAN_ACCESS_PASSWORD=CHANGE_ME

# --- Passive Intelligence APIs (Scan-Worker, Phase 0a) ---
SHODAN_API_KEY=
ABUSEIPDB_API_KEY=
SECURITYTRAILS_API_KEY=

# --- Threat Intelligence (Scan-Worker, Phase 3) ---
NVD_API_KEY=

# --- WPScan (WordPress vulnerability scanner) ---
WPSCAN_API_TOKEN=

# --- Stripe Payment Flow (PA-1 / VEC-33) ---
# Von der CEO als Deploy-Secrets zu liefern. Ohne STRIPE_SECRET_KEY werden
# KEINE Abos aktiviert (POST /api/subscriptions -> 503 payment_not_configured).
# Live: sk_live_... / whsec_... | Staging-Test: sk_test_... / whsec_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price-ID je Paket (Jahres-Abo); STRIPE_PRICE_DEFAULT als Fallback fuer alle Pakete.
STRIPE_PRICE_DEFAULT=
STRIPE_PRICE_WEBCHECK=
STRIPE_PRICE_PERIMETER=
STRIPE_PRICE_COMPLIANCE=
STRIPE_PRICE_SUPPLYCHAIN=
STRIPE_PRICE_INSURANCE=
# VEC-436: one-time Price-ID fuer den kostenpflichtigen Einzelscan-Kauf
# (mode=payment). STRIKT getrennt vom Jahres-Abo (kein DEFAULT-Fallback).
# Heute nur Perimeter (EUR 490 einmalig, Sandbox-Test-Price).
STRIPE_PRICE_PERIMETER_ONETIME=
# Redirect-URLs nach Checkout (optional, sonst aus APP_BASE_URL abgeleitet).
APP_BASE_URL=https://scan.vectigal.tech
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
# VEC-436: Redirect-URLs fuer den Einzelscan-Checkout (optional). Erfolg fuehrt
# sonst auf /scan/<orderId>?checkout=success, Abbruch auf /scan/new?checkout=cancelled.
STRIPE_ORDER_SUCCESS_URL=
STRIPE_ORDER_CANCEL_URL=
# --- E-Mail (Resend) + Lead-Routing (VEC-36) ---
# Ohne RESEND_API_KEY ist der E-Mail-Versand deaktiviert; Leads werden trotzdem
# in der DB persistiert und sind ueber GET /api/leads (Admin) abrufbar.
RESEND_API_KEY=
RESEND_FROM_EMAIL=VectiScan <noreply@vectigal.tech>
# Routing-Ziel fuer eingehende Demo-/Lead-Anfragen (Vertriebs-Posteingang).
# Komma-separiert = mehrere Empfaenger (Lead landet in jedem Postfach).
# MUSS ein real abgerufenes Postfach sein: support@vectiscan.de wird an
# kontakt@vectigal.ai weitergeleitet. (VEC-36: das alte 'kontakt@vectigal.gmbh'
# war UNbetreut -> routed:true, aber kein Lead kam an.)
SALES_LEAD_EMAIL=support@vectiscan.de,kontakt@vectigal.ai

# --- Keycloak-SSO (VEC-421 / VEC-437 C1 + VEC-439 C3) ---
# Profil `sso` (keycloak, keycloak-db, oauth2-proxy). NICHT im Default-Deploy —
# Aktivierung ausschliesslich via CI-Job `ops-keycloak-provision`
# (COMPOSE_PROFILES=crm,sso). Alle Werte sind maskierte CI/CD-Variablen, NICHT
# ins Repo committen. Lokal leer lassen (Default-Stack laeuft ohne SSO).
KC_DB_PASSWORD=
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=
# Client-Secrets der Realm-Clients (vectiscan-grafana / vectiscan-oauth2-proxy).
KEYCLOAK_GRAFANA_SECRET=
KEYCLOAK_OAUTH2_PROXY_SECRET=
# oauth2-proxy Cookie-Signatur (VEC-439 C3). 16/24/32-Byte, URL-safe base64.
# Erzeugen: openssl rand -base64 32 | tr -- '+/' '-_'
OAUTH2_PROXY_COOKIE_SECRET=

# --- Image Tag (set by CI/CD, default: latest) ---
TAG=latest
