# VectiScan — Production Environment Variables
# Copy to .env and fill in actual values before deployment.
#
# Required GitLab CI/CD Variables (Settings → CI/CD → Variables):
#   DB_USER, DB_PASSWORD, DB_NAME,
#   MINIO_ACCESS_KEY, MINIO_SECRET_KEY,
#   ANTHROPIC_API_KEY, VECTISCAN_ACCESS_PASSWORD

# --- PostgreSQL ---
DB_USER=vectiscan
DB_PASSWORD=CHANGE_ME
DB_NAME=vectiscan

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME

# --- Claude API (Report-Worker) ---
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# --- Access Password (Frontend Login) ---
VECTISCAN_ACCESS_PASSWORD=CHANGE_ME

# --- Passive Intelligence APIs (Scan-Worker, Phase 0a) ---
SHODAN_API_KEY=
ABUSEIPDB_API_KEY=
SECURITYTRAILS_API_KEY=

# --- Threat Intelligence (Scan-Worker, Phase 3) ---
NVD_API_KEY=

# --- Image Tag (set by CI/CD, default: latest) ---
TAG=latest
